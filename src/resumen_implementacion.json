{
  "nombre_proyecto": "Módulo de Auditoría y Analítica Avanzada de Tesorería",
  "fecha_implementacion": "2026-05-06",
  "version": "2.0",
  "descripcion": "Interfaz avanzada de tesorería con auditoría completa, analítica en tiempo real y validación de duplicados",
  "objetivos_logrados": [
    "✅ Vista de Auditoría de Alumno con historial completo de pagos",
    "✅ Desglose FIFO expandible en cada pago",
    "✅ Comparativo de deudas facturadas vs pagadas",
    "✅ Dashboard de Caja con analítica en tiempo real",
    "✅ Conteo de transacciones por método de pago",
    "✅ Lista de últimos pagos registrados en la sesión",
    "✅ Validación dinámica de duplicados en frontend"
  ],
  "endpoints_backend_utilizados": {
    "deudas": {
      "endpoint": "GET /api/pagos/deudas/",
      "parametros": {
        "alumno": "int (ID del alumno)",
        "incluir_pagadas": "boolean (default: false)",
        "ordenamiento": "fecha_vencimiento (default)"
      },
      "respuesta": [
        {
          "id": "int",
          "alumno": "int",
          "concepto_detail": {
            "id": "int",
            "nombre": "string",
            "tipo": "string (CUOTA_INGRESO|MATRICULA|PENSION)"
          },
          "monto_total": "decimal",
          "monto_pagado": "decimal",
          "saldo_pendiente": "decimal",
          "mes": "int | null",
          "anio": "int",
          "fecha_vencimiento": "datetime",
          "estado": "string (Pendiente|Parcial|Pagado)"
        }
      ],
      "utilizado_en": "AuditoriaAlumno.jsx - Comparativo de deudas"
    },
    "pagos_by_alumno": {
      "endpoint": "GET /api/pagos/pagos/?alumno={id}",
      "parametros": {
        "alumno": "int (ID del alumno)",
        "ordenamiento": "-fecha_pago (default)"
      },
      "respuesta": [
        {
          "id": "int",
          "alumno": "int",
          "alumno_detail": {
            "id": "int",
            "nombres": "string",
            "apellidos": "string"
          },
          "monto_total_entregado": "decimal",
          "fecha_pago": "datetime",
          "metodo_pago": "string (Efectivo|Yape|etc)",
          "numero_operacion": "string | null",
          "usuario_registro": "int",
          "observaciones": "string",
          "asignaciones": [
            {
              "id": "int",
              "deuda": "int",
              "monto_aplicado": "decimal",
              "deuda_detail": {
                "concepto": "string",
                "mes": "int | null",
                "monto_total": "decimal",
                "saldo_pendiente": "decimal"
              }
            }
          ]
        }
      ],
      "utilizado_en": [
        "AuditoriaAlumno.jsx - Historial de pagos",
        "RegistroPago.jsx - Validación de duplicados (numero_operacion)",
        "GestionCaja.jsx - Últimos pagos del día"
      ]
    },
    "resumen_ingresos": {
      "endpoint": "GET /api/pagos/cajas/{id}/resumen_ingresos/",
      "parametros": {
        "id": "int (ID de la caja)"
      },
      "respuesta": {
        "monto_inicial": "decimal",
        "total_recaudado": "decimal",
        "total_con_inicial": "decimal",
        "cantidad_pagos": "int",
        "resumen_por_metodo": [
          {
            "metodo_pago": "string",
            "cantidad": "int",
            "total": "decimal"
          }
        ]
      },
      "utilizado_en": "GestionCaja.jsx - Dashboard con analítica"
    },
    "mi_estado_caja": {
      "endpoint": "GET /api/pagos/cajas/mi_estado/",
      "respuesta": {
        "abierta": "boolean",
        "caja": {
          "id": "int",
          "usuario": "int",
          "estado": "string (Abierta|Cerrada)",
          "fecha_apertura": "datetime",
          "fecha_cierre": "datetime | null",
          "monto_inicial": "decimal",
          "monto_total_pagos": "decimal"
        }
      },
      "utilizado_en": "GestionCaja.jsx - Estado actual de caja"
    }
  },
